DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_UPSTREAM_PROTOCOL=anthropic

# Local Anthropic-compatible proxy listener.
SERVER_HOST=127.0.0.1
SERVER_PORT=3000

# Default backend model when the client sends an unknown Claude model name.
DEFAULT_DEEPSEEK_MODEL=deepseek-v4-flash

# Claude-name prefix mapping used by the proxy before forwarding to DeepSeek.
CLAUDE_OPUS_MODEL=deepseek-v4-pro
CLAUDE_SONNET_MODEL=deepseek-v4-flash
CLAUDE_HAIKU_MODEL=deepseek-v4-flash

# DeepSeek V4 thinking mode:
# - auto: disable by default, but pass through client-requested thinking/effort
# - disabled: always force thinking off
# - enabled: default thinking on when the client does not specify it
DEEPSEEK_THINKING=auto
DEEPSEEK_REASONING_EFFORT=high
